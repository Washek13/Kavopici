@inherits LayoutComponentBase
@implements IDisposable
@inject AppState AppState
@inject UpdateState UpdateState
@inject IUpdateService UpdateService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IThemedLocalizer L

<div class="app-container">
    @if (UpdateState.IsUpdateAvailable)
    {
        <div class="update-banner">
            <div class="update-banner-content">
                <span class="update-banner-version">@string.Format(L["Msg_UpdateAvailable"], UpdateState.AvailableUpdate!.Version)</span>
                @if (!string.IsNullOrWhiteSpace(UpdateState.AvailableUpdate!.ReleaseNotes))
                {
                    <div class="update-banner-notes">@UpdateState.AvailableUpdate.ReleaseNotes</div>
                }
            </div>
            @if (isDownloading)
            {
                <span>@L["Msg_Downloading"]</span>
            }
            else
            {
                <button class="btn btn-sm" style="background:var(--amber-gold);color:var(--coffee-dark);border-color:var(--amber-gold);"
                        @onclick="InstallUpdate">
                    @L["Btn_Update"]
                </button>
            }
        </div>
    }

    @if (AppState.IsLoggedIn)
    {
        <header class="app-header">
            <button class="header-brand" @onclick="GoToDashboard">
                <span class="header-logo-circle">
                    @if (AppState.CurrentTheme == Theme.Tea)
                    {
                        <img src="icon-tea.svg" alt="" />
                    }
                    else
                    {
                        <img src="icon-80.png" alt="" />
                    }
                </span>
                <span class="header-title">@L["Brand_AppName"]</span>
            </button>
            <nav class="header-nav">
                <button class="nav-btn @(IsRoute("/dashboard") ? "active" : "")" @onclick="GoToDashboard">@L["Nav_Dashboard"]</button>
                <button class="nav-btn @(IsRoute("/statistics") || IsRoute("/blend") ? "active" : "")" @onclick="GoToStatistics">@L["Nav_Statistics"]</button>
                <button class="nav-btn @(IsRoute("/comparison") ? "active" : "")" @onclick="GoToComparison">@L["Nav_Comparison"]</button>
                @if (AppState.IsAdmin)
                {
                    <button class="nav-btn @(IsRoute("/admin") ? "active" : "")" @onclick="GoToAdmin">@L["Nav_Admin"]</button>
                }
            </nav>
            <div class="header-spacer"></div>
            <div class="header-user">
                <UserInitials Name="@AppState.CurrentUser!.Name" Size="28" />
                <span class="user-name">@AppState.CurrentUser!.Name</span>
                <select class="lang-select" value="@currentCulture" @onchange="OnLanguageChanged">
                    <option value="cs">CS</option>
                    <option value="sk">SK</option>
                    <option value="en">EN</option>
                    <option value="de">DE</option>
                </select>
                <a href="@BugReportUrl" target="_blank" rel="noopener noreferrer"
                   class="btn btn-ghost btn-sm" title="@L["Tooltip_ReportBug"]"
                   style="text-decoration:none;font-size:14px;line-height:1;padding:6px 10px;color:var(--cream);border-color:rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);">
                    🪲
                </a>
                <button class="btn btn-ghost btn-sm" @onclick="Logout"
                        style="color:var(--cream);border-color:rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);">
                    @L["Nav_Logout"]
                </button>
            </div>
        </header>
    }

    <main class="app-main wide">
        @Body
    </main>
</div>

@code {
    private bool isDownloading;
    private string currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChanged;
        AppState.OnThemeChange += OnThemeChanged;
        UpdateState.OnChange += OnUpdateStateChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnAppStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnUpdateStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void OnThemeChanged()
    {
        await InvokeAsync(async () =>
        {
            await ApplyThemeToBodyAsync();
            StateHasChanged();
        });
    }

    private async Task ApplyThemeToBodyAsync()
    {
        await JS.InvokeVoidAsync("setThemeClass",
            AppState.CurrentTheme == Kavopici.Models.Enums.Theme.Tea ? "Tea" : "Coffee");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ApplyThemeToBodyAsync();
    }

    private async Task InstallUpdate()
    {
        if (UpdateState.AvailableUpdate is null) return;
        isDownloading = true;
        await UpdateService.DownloadAndInstallUpdateAsync(UpdateState.AvailableUpdate);
    }

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        var culture = e.Value?.ToString();
        if (!string.IsNullOrEmpty(culture))
        {
            await JS.InvokeVoidAsync("setCultureCookie", culture);
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
    }

    private bool IsRoute(string prefix)
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        return path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    }


    private void GoToDashboard() => Nav.NavigateTo("/dashboard");
    private void GoToStatistics() => Nav.NavigateTo("/statistics");
    private void GoToComparison() => Nav.NavigateTo("/comparison");
    private void GoToAdmin() => Nav.NavigateTo("/admin");

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("clearUserCookie");
        AppState.Logout();
        Nav.NavigateTo("/");
    }

    private const string GitHubOwner = "Washek13";
    private const string GitHubRepo = "Kavopici";

    private string BugReportUrl => BuildBugReportUrl();

    private string BuildBugReportUrl()
    {
        var version = System.Reflection.Assembly.GetExecutingAssembly()
            .GetName().Version?.ToString() ?? "unknown";

        var body = string.Format(L["BugReport_Body"], version);

        var encodedBody = Uri.EscapeDataString(body);
        return $"https://github.com/{GitHubOwner}/{GitHubRepo}/issues/new?labels=bug&body={encodedBody}";
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
        AppState.OnThemeChange -= OnThemeChanged;
        UpdateState.OnChange -= OnUpdateStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
