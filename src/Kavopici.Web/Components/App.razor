<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kávopíči</title>
    <base href="/" />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <link rel="stylesheet" href="css/app.css" />
    <HeadOutlet @rendermode="RenderMode.InteractiveServer" />
</head>
<body>
    <Routes CultureName="@System.Globalization.CultureInfo.CurrentUICulture.Name"
            @rendermode="RenderMode.InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.setCultureCookie = function (culture) {
            document.cookie = '.AspNetCore.Culture=c=' + culture + '|uic=' + culture + '; path=/; max-age=' + (365 * 24 * 60 * 60);
        };
        window.getCultureCookie = function () {
            var m = document.cookie.match(/\.AspNetCore\.Culture=([^;]+)/);
            return m ? decodeURIComponent(m[1]) : null;
        };
        window.downloadFile = function (fileName, contentType, byteArray) {
            var blob = new Blob([byteArray], { type: contentType });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>
</body>
</html>

