@* Interactive star rating component (1–10) *@
<div class="star-rating @(ReadOnly ? "readonly" : "") @(Large ? "large" : "") @(Small ? "small" : "")"
     @onmouseleave="OnHoverOut">
    @for (int i = 1; i <= MaxStars; i++)
    {
        var starValue = i;
        var filled = !ReadOnly && _hoverValue > 0
            ? starValue <= _hoverValue
            : starValue <= Value;
        var hovering = !ReadOnly && _hoverValue == starValue;
        <span class="star @(filled ? "filled" : "") @(hovering ? "hover" : "")"
              @onclick="() => OnClick(starValue)"
              @onmouseover="() => OnHover(starValue)"
              title="@starValue">&#9733;</span>
    }
    @if (ShowValue && Value > 0)
    {
        <span class="star-value">@Value / @MaxStars</span>
    }
</div>

@code {
    private const int MaxStars = 10;

    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Large { get; set; }
    [Parameter] public bool Small { get; set; }
    [Parameter] public bool ShowValue { get; set; } = true;

    private int _hoverValue;

    private async Task OnClick(int star)
    {
        if (ReadOnly) return;
        Value = star;
        await ValueChanged.InvokeAsync(star);
    }

    private void OnHover(int star)
    {
        if (!ReadOnly) _hoverValue = star;
    }

    private void OnHoverOut() => _hoverValue = 0;
}
