@{
    var notes = NoteNames.ToArray();
    if (notes.Length == 0) return;
    var activeSet = new HashSet<string>(Active ?? Array.Empty<string>());
    var counts = Counts ?? new Dictionary<string, int>();
    var maxCount = counts.Values.Count > 0 ? Math.Max(counts.Values.Max(), 1) : 1;
    var cx = 130; var cy = 130; var rOuter = 120; var rInner = 50;
    if (Compact) { cx = 110; cy = 110; rOuter = 100; rInner = 42; }
    var viewbox = Compact ? "0 0 220 220" : "0 0 260 260";
    var vbHeight = Compact ? 230 : 260;
}
<svg viewBox="@viewbox" style="width:100%;max-width:@(Compact ? "240" : "300")px;display:block;margin:0 auto;height:@(vbHeight)px;">
    @for (int i = 0; i < notes.Length; i++)
    {
        var s = notes[i];
        var a0 = (i / (double)notes.Length) * Math.PI * 2 - Math.PI / 2;
        var a1 = ((i + 1) / (double)notes.Length) * Math.PI * 2 - Math.PI / 2;
        var isActive = activeSet.Contains(s);
        var cnt = counts.TryGetValue(s, out var c) ? c : 0;
        var intensity = cnt / (double)maxCount;
        double r;
        if (Compact)
        {
            r = rOuter;
        }
        else
        {
            r = rInner + (rOuter - rInner) * (isActive ? Math.Max(0.4, intensity) : 0.25);
        }
        var x0o = cx + Math.Cos(a0) * r;
        var y0o = cy + Math.Sin(a0) * r;
        var x1o = cx + Math.Cos(a1) * r;
        var y1o = cy + Math.Sin(a1) * r;
        var x0i = cx + Math.Cos(a0) * rInner;
        var y0i = cy + Math.Sin(a0) * rInner;
        var x1i = cx + Math.Cos(a1) * rInner;
        var y1i = cy + Math.Sin(a1) * rInner;
        var baseColor = TastingNoteHelpers.NoteColor(s);
        var fill = isActive ? baseColor : (Compact ? "#f0e9dd" : baseColor);
        var fillOp = isActive ? 0.92 : (Compact ? 0.55 : 0.32);
        var am = (a0 + a1) / 2;
        double tx, ty;
        if (Compact)
        {
            tx = cx + Math.Cos(am) * ((rOuter + rInner) / 2.0);
            ty = cy + Math.Sin(am) * ((rOuter + rInner) / 2.0);
        }
        else
        {
            tx = cx + Math.Cos(am) * (rOuter + 8);
            ty = cy + Math.Sin(am) * (rOuter + 8);
        }
        var pathD = $"M {Fmt(x0o)} {Fmt(y0o)} A {Fmt(r)} {Fmt(r)} 0 0 1 {Fmt(x1o)} {Fmt(y1o)} L {Fmt(x1i)} {Fmt(y1i)} A {Fmt(rInner)} {Fmt(rInner)} 0 0 0 {Fmt(x0i)} {Fmt(y0i)} Z";
        <g>
            <path d="@pathD" fill="@fill" stroke="#fff" stroke-width="2" opacity="@Fmt(fillOp)" />
            <text x="@Fmt(tx)" y="@Fmt(ty)" text-anchor="middle" dominant-baseline="middle"
                  font-size="@(Compact ? 10.5 : 11)" font-weight="@(isActive ? 700 : 500)"
                  fill="@(isActive && Compact ? "#fff" : (isActive ? "var(--coffee-dark)" : "var(--coffee-medium)"))">
                @s
            </text>
            @if (cnt > 0 && !Compact)
            {
                var lx = cx + Math.Cos(am) * (r - 12);
                var ly = cy + Math.Sin(am) * (r - 12);
                <text x="@Fmt(lx)" y="@Fmt(ly)" text-anchor="middle" dominant-baseline="middle" font-size="11" font-weight="700" fill="@(isActive ? "#fff" : "var(--coffee-medium)")">@cnt</text>
            }
        </g>
    }
    <circle cx="@cx" cy="@cy" r="@(rInner - 2)" fill="var(--off-white)" stroke="var(--border)" />
    <text x="@cx" y="@(cy - 4)" text-anchor="middle" font-size="11" fill="var(--coffee-medium)" letter-spacing="1">FLAVOR</text>
    <text x="@cx" y="@(cy + 10)" text-anchor="middle" font-size="11" fill="var(--coffee-medium)" letter-spacing="1">WHEEL</text>
</svg>

@code {
    [Parameter] public IEnumerable<string>? Active { get; set; }
    [Parameter] public Dictionary<string, int>? Counts { get; set; }
    [Parameter, EditorRequired] public IEnumerable<string> NoteNames { get; set; } = Array.Empty<string>();
    [Parameter] public bool Compact { get; set; }

    private static string Fmt(double v) => v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
}
