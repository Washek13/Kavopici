@inject IStringLocalizer<SharedResources> L

<div class="blend-card">
    <h3 class="blend-name">@Blend.Name</h3>
    <div class="blend-details">
        <div class="blend-detail"><span class="label">@L["Label_Roaster"]:</span> @Blend.Roaster</div>
        @if (!string.IsNullOrEmpty(Blend.Origin))
        {
            <div class="blend-detail"><span class="label">@L["Label_Origin"]:</span> @Blend.Origin</div>
        }
        <div class="blend-detail"><span class="label">@L["Label_Roasting"]:</span> @L[$"RoastLevel_{Blend.RoastLevel}"]</div>
        <div class="blend-detail"><span class="label">@L["Label_Supplier"]:</span> @Blend.Supplier.Name</div>
        @if (Blend.PricePerKg.HasValue)
        {
            <div class="blend-detail"><span class="label">@L["Label_PricePerKg"]:</span> @Blend.PricePerKg.Value.ToString("F0") Kč</div>
        }
    </div>
    @if (!string.IsNullOrEmpty(SessionComment))
    {
        <div class="blend-comment">@SessionComment</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CoffeeBlend Blend { get; set; } = null!;
    [Parameter] public string? SessionComment { get; set; }
}
